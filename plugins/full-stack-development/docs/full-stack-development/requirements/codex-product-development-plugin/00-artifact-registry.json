{
  "schemaVersion": "full-stack-development.artifact-registry.v0.2.0",
  "featureSlug": "codex-product-development-plugin",
  "artifacts": [
    {
      "id": "stage-state",
      "path": "00-stage.json",
      "producer": "stage-gate-reviewer",
      "consumers": ["all-skills", "review-stage-gate", "review-completion-gate"],
      "requiredForStages": ["all"],
      "status": "approved",
      "passCondition": "当前阶段、下一允许阶段、审批、变更、阻断 gate 和必需证据都可被机器读取。",
      "failureRoute": "stage-gate-reviewer"
    },
    {
      "id": "artifact-registry",
      "path": "00-artifact-registry.json",
      "producer": "artifact-contract-manager",
      "consumers": ["stage-gate-reviewer", "change-control", "implementation-planner"],
      "requiredForStages": ["implementation-plan-ready", "implementation-in-progress", "verified"],
      "status": "approved",
      "passCondition": "每个 artifact 有唯一 producer、明确 consumers、PASS 条件和失败回退。",
      "failureRoute": "artifact-contract-manager"
    },
    {
      "id": "requirement-discovery",
      "path": "01-intake/requirement-discovery.md",
      "producer": "requirement-discovery",
      "consumers": ["product-scope-builder", "product-spec-builder", "pressure-test-runner"],
      "requiredForStages": ["product-scope", "implementation-plan-ready"],
      "status": "approved",
      "passCondition": "用户目标、事实、AI 假设、开放问题、非目标、压力测试约束已分离。",
      "failureRoute": "requirement-discovery"
    },
    {
      "id": "product-scope",
      "path": "02-product/product-scope.md",
      "producer": "product-scope-builder",
      "consumers": ["implementation-planner", "stage-gate-reviewer"],
      "requiredForStages": ["implementation-plan-ready"],
      "status": "approved",
      "passCondition": "P0/P1/P2、非目标、可延期能力、首版验收边界明确。",
      "failureRoute": "product-scope-builder"
    },
    {
      "id": "system-contract",
      "path": "03-architecture/system-contract.md",
      "producer": "artifact-contract-manager",
      "consumers": ["implementation-planner", "dev-builder", "code-review"],
      "requiredForStages": ["implementation-plan-ready", "implementation-in-progress"],
      "status": "approved",
      "passCondition": "插件目标架构、MCP 工具边界、Skill 拆分、测试入口和兼容策略明确。",
      "failureRoute": "artifact-contract-manager"
    },
    {
      "id": "pressure-test-matrix",
      "path": "04-pressure-tests/stage-pressure-test-matrix.md",
      "producer": "pressure-test-planner",
      "consumers": ["dev-builder", "stage-gate-reviewer", "code-review", "release-builder"],
      "requiredForStages": ["implementation-in-progress", "verified"],
      "status": "approved",
      "passCondition": "每个阶段都有跳步、过度澄清、下游交接、需求变更和完成前验证的压力场景。",
      "failureRoute": "pressure-test-planner"
    },
    {
      "id": "visual-evidence-gate",
      "path": "mcp-server/src/visual-evidence.js",
      "producer": "visual-evidence-gate",
      "consumers": ["stage-gate-reviewer", "hero-ui-craft", "implementation-planner"],
      "requiredForStages": ["visual-approved", "implementation-plan-ready", "implementation-in-progress"],
      "status": "approved",
      "passCondition": "Pencil/Figma 视觉证据必须包含 desktop、mobile、component-detail、state-matrix、用户批准记录和当前 changeId；缺失、过期或未批准必须阻断实现。",
      "failureRoute": "visual-evidence-gate"
    },
    {
      "id": "tailwind-reference-adapter",
      "path": "mcp-server/src/tailwind-reference.js",
      "producer": "tailwind-reference-adapter",
      "consumers": ["visual-design-orchestrator", "hero-ui-craft", "implementation-planner"],
      "requiredForStages": ["visual-requirements", "visual-design-ready"],
      "status": "approved",
      "passCondition": "本地 TailwindUI/Tailwind Plus 资源只能作为 reference-only 索引和视觉参考，禁止复制源码、打包模板或用 Catalyst/Headless UI 绕过 HeroUI。",
      "failureRoute": "tailwind-reference-adapter"
    },
    {
      "id": "visual-design-orchestration",
      "path": "mcp-server/src/visual-orchestration.js",
      "producer": "visual-design-orchestrator",
      "consumers": ["visual-evidence-gate", "stage-gate-reviewer", "implementation-planner"],
      "requiredForStages": ["visual-design-ready", "visual-approved", "implementation-plan-ready"],
      "status": "approved",
      "passCondition": "Pencil/Figma 编排必须包含前置 gate、画板清单、工具调用计划、导出、用户批准、visual evidence review 和 implementation gate。",
      "failureRoute": "visual-design-orchestrator"
    },
    {
      "id": "quality-audits",
      "path": "mcp-server/src/quality-audits.js",
      "producer": "quality-auditor",
      "consumers": ["completion-verifier", "stage-gate-reviewer", "release-builder"],
      "requiredForStages": ["verification-in-progress", "verified", "released"],
      "status": "approved",
      "passCondition": "截图指标、HeroUI 组件图谱、后端/API 合同覆盖、代码审查证据和 HeroUI docs freshness 均可被机器审查并返回稳定 blocker。",
      "failureRoute": "quality-auditor"
    },
    {
      "id": "implementation-plan",
      "path": "05-implementation/full-fusion-implementation-plan.md",
      "producer": "implementation-planner",
      "consumers": ["dev-builder", "code-review", "release-builder"],
      "requiredForStages": ["implementation-in-progress"],
      "status": "ready-for-user-review",
      "passCondition": "任务可按阶段执行，每个阶段有文件、接口、测试、压力测试、flow profile、Superpowers execution handoff 和验收命令。",
      "failureRoute": "implementation-planner"
    },
    {
      "id": "execution-discipline-and-flow-profile",
      "path": "mcp-server/src/implementation-plan.js",
      "producer": "implementation-planner",
      "consumers": ["dev-builder", "code-review", "completion-verifier", "release-builder"],
      "requiredForStages": ["implementation-plan-ready", "implementation-in-progress", "verified"],
      "status": "approved",
      "passCondition": "实现计划必须选择 strict-fullstack、strict-ui、light-change 或 debug-fix，并生成 TDD、subagent/executing-plans、code review、verification-before-completion、finishing branch 的 Superpowers 执行交接。",
      "failureRoute": "implementation-planner"
    }
  ],
  "addNewArtifactRule": {
    "requiredFields": ["id", "path", "producer", "consumers", "requiredForStages", "status", "passCondition", "failureRoute"],
    "rule": "新增 artifact 前必须写清谁生产、谁消费、如何 PASS、失败回退到哪里；写不清就不允许新增。"
  }
}
